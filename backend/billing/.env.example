# Trellis Billing Service — Environment Variables

# Database (same as EHR for dev, separate in production)
DB_HOST=127.0.0.1
DB_PORT=5432
DB_NAME=trellis
DB_USER=postgres
DB_PASSWORD=
DATABASE_URL=postgresql://postgres:@127.0.0.1:5432/trellis

# CORS origins (comma-separated list of EHR installation URLs)
ALLOWED_ORIGINS=http://localhost:5173

# Stedi (claim submission, ERA, eligibility)
# Get your API key at https://www.stedi.com/
STEDI_API_KEY=

# Stripe Connect (patient payments)
# Get keys at https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Platform fee percentage charged on patient payments (default: 2.9%)
PLATFORM_FEE_PERCENT=2.9
