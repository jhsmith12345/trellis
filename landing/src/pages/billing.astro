---
import Layout from '../layouts/Layout.astro'
import Section from '../components/Section.astro'
import Button from '../components/Button.astro'

const capabilities = [
  {
    title: 'Claim Submission',
    description: 'Generate CMS-1500 and 837P electronic claims directly from signed clinical notes. Automated scrubbing catches errors before submission. Transmit to any payer via Stedi clearinghouse integration.',
    icon: '<svg class="w-6 h-6 text-sage-600" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M22 2L11 13"/><path d="M22 2l-7 20-4-9-9-4 20-7z"/></svg>',
  },
  {
    title: 'Eligibility Verification',
    description: 'Check patient eligibility and benefits in real time before the session starts. Know copays, deductibles, and authorization requirements upfront — not after the claim bounces.',
    icon: '<svg class="w-6 h-6 text-sage-600" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>',
  },
  {
    title: 'Payment Posting',
    description: 'ERA/835 remittance files are parsed and posted automatically. Insurance payments match to the correct encounter. Contractual adjustments, co-insurance, and patient responsibility calculate instantly.',
    icon: '<svg class="w-6 h-6 text-sage-600" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg>',
  },
  {
    title: 'Patient Payments',
    description: 'Stripe-powered patient payment collection. Automatic invoices with secure payment links. Patients pay online, the ledger updates in real time, and receipts send automatically.',
    icon: '<svg class="w-6 h-6 text-sage-600" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="1" y="4" width="22" height="16" rx="2" ry="2"/><line x1="1" y1="10" x2="23" y2="10"/></svg>',
  },
  {
    title: 'Authorization Tracking',
    description: 'Track prior authorizations across clients. Get alerts before sessions exhaust their approved units. Never have a claim denied for missing auth again.',
    icon: '<svg class="w-6 h-6 text-sage-600" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><polyline points="9 12 11 14 15 10"/></svg>',
  },
  {
    title: 'Denial Management',
    description: 'Denials surface automatically with reason codes and suggested actions. Track appeals, resubmissions, and resolution status. Pattern detection highlights systemic issues before they cost you revenue.',
    icon: '<svg class="w-6 h-6 text-sage-600" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>',
  },
  {
    title: 'Financial Reporting',
    description: 'Revenue dashboards, aging reports, payer performance, and collection rates at a glance. Understand your practice finances without exporting CSVs or building spreadsheets.',
    icon: '<svg class="w-6 h-6 text-sage-600" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="20" x2="18" y2="10"/><line x1="12" y1="20" x2="12" y2="4"/><line x1="6" y1="20" x2="6" y2="14"/></svg>',
  },
  {
    title: 'Superbill Generation',
    description: 'Automatically generate branded superbills from signed notes. Include diagnosis codes, CPT codes, provider NPI, and clinician signature. PDF download or direct send to clients.',
    icon: '<svg class="w-6 h-6 text-sage-600" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="12" y1="18" x2="12" y2="12"/><line x1="9" y1="15" x2="15" y2="15"/></svg>',
  },
]

const flowSteps = [
  { label: 'Session Complete', detail: 'Clinician finishes appointment', color: 'warm' },
  { label: 'Note Signed', detail: 'Clinical documentation reviewed and signed', color: 'sage' },
  { label: 'Claim Generated', detail: 'CMS-1500/837P auto-built from note data', color: 'sage' },
  { label: 'Claim Submitted', detail: 'Transmitted to payer via clearinghouse', color: 'sage' },
  { label: 'Insurance Adjudicates', detail: 'Payer processes and returns ERA/835', color: 'gold' },
  { label: 'Payment Posted', detail: 'Remittance auto-applied to encounter', color: 'gold' },
  { label: 'Patient Invoiced', detail: 'Remaining balance sent with payment link', color: 'terra' },
  { label: 'Payment Collected', detail: 'Stripe processes, ledger reconciles', color: 'sage' },
]
---

<Layout title="Automated Billing — Trellis" description="Revenue cycle management for behavioral health. Automated claim submission, payment posting, patient collections, and denial management.">

  <!-- HERO -->
  <section class="relative hero-pattern pt-28 pb-20 md:pt-36 md:pb-24 overflow-hidden">
    <div class="absolute top-32 -right-24 w-80 h-80 border border-gold-200/30 rounded-full opacity-30"></div>
    <div class="absolute -bottom-32 -left-16 w-64 h-64 border border-sage-200/20 rounded-full opacity-20"></div>

    <div class="max-w-[1200px] mx-auto px-6 relative z-10">
      <div class="max-w-3xl">
        <div class="animate-fade-in">
          <span class="inline-flex items-center gap-2 px-3 py-1 text-xs font-medium text-terra-700 bg-terra-100 rounded-full mb-6">
            <span class="w-1.5 h-1.5 rounded-full bg-terra-500"></span>
            Revenue Cycle Management
          </span>
        </div>

        <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold tracking-tight text-warm-950 leading-[1.1] mb-6 animate-on-scroll">
          Automated revenue cycle<br class="hidden sm:block" />
          <span class="text-sage-600">for behavioral health.</span>
        </h1>

        <p class="text-lg md:text-xl text-warm-600 max-w-2xl mb-10 leading-relaxed animate-on-scroll delay-100">
          From signed note to collected payment — fully automated. No more downloading claim files, manually posting payments, or chasing patient balances.
        </p>

        <div class="flex flex-col sm:flex-row gap-4 animate-on-scroll delay-200">
          <Button href="/contact" variant="primary" size="lg">
            Add Billing to Your Practice
          </Button>
          <Button href="/#product" variant="secondary" size="lg">
            See the Full Platform
          </Button>
        </div>
      </div>
    </div>
  </section>

  <!-- HOW IT CONNECTS -->
  <Section background="alt">
    <div class="max-w-3xl mx-auto text-center mb-12">
      <h2 class="text-3xl md:text-4xl font-bold text-warm-900 mb-4 animate-on-scroll">
        Clinical workflow meets revenue cycle.
      </h2>
      <p class="text-lg text-warm-600 animate-on-scroll delay-100">
        Trellis Billing isn't a separate system. It's wired directly into your clinical documentation. The moment a note is signed, billing begins.
      </p>
    </div>

    <!-- Flow diagram -->
    <div class="max-w-2xl mx-auto">
      <div class="relative">
        {flowSteps.map((step, i) => (
          <div class:list={['flex items-start gap-5 animate-on-scroll', `delay-${(i % 4 + 1) * 100}`]}>
            <div class="flex flex-col items-center">
              <div class:list={[
                'w-11 h-11 rounded-full flex items-center justify-center text-white text-sm font-bold shrink-0',
                step.color === 'sage' ? 'bg-sage-600' :
                step.color === 'gold' ? 'bg-gold-500' :
                step.color === 'terra' ? 'bg-terra-500' : 'bg-warm-500',
              ]}>
                {i + 1}
              </div>
              {i < flowSteps.length - 1 && (
                <div class="w-0.5 h-8 bg-warm-200"></div>
              )}
            </div>
            <div class="pt-2 pb-4">
              <p class="font-semibold text-warm-900">{step.label}</p>
              <p class="text-warm-500 text-sm mt-0.5">{step.detail}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </Section>

  <!-- CAPABILITIES -->
  <Section>
    <div class="text-center mb-16">
      <h2 class="text-3xl md:text-4xl font-bold text-warm-900 mb-4 animate-on-scroll">
        Full-cycle revenue management.
      </h2>
      <p class="text-lg text-warm-600 max-w-2xl mx-auto animate-on-scroll delay-100">
        Every component of the billing workflow, automated and integrated.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
      {capabilities.map((cap, i) => (
        <div class:list={['group bg-white rounded-2xl p-6 border border-warm-200 hover:border-sage-300 hover:shadow-lg transition-all duration-300 animate-on-scroll', `delay-${(i % 4 + 1) * 100}`]}>
          <div class="w-11 h-11 rounded-xl bg-sage-50 flex items-center justify-center mb-4 group-hover:bg-sage-100 transition-colors">
            <Fragment set:html={cap.icon} />
          </div>
          <h3 class="text-base font-semibold text-warm-900 mb-2">{cap.title}</h3>
          <p class="text-warm-600 text-sm leading-relaxed">{cap.description}</p>
        </div>
      ))}
    </div>
  </Section>

  <!-- INTEGRATION CALLOUT -->
  <Section background="sage">
    <div class="max-w-3xl mx-auto text-center">
      <h2 class="text-3xl md:text-4xl font-bold text-warm-900 mb-6 animate-on-scroll">
        Works with your existing Trellis installation.
      </h2>
      <p class="text-lg text-warm-600 leading-relaxed mb-4 animate-on-scroll delay-100">
        Already running Trellis EHR? Billing plugs in seamlessly. Your clinical data feeds directly into claim generation — no duplicate entry, no data migration, no new system to learn.
      </p>
      <p class="text-lg text-warm-600 leading-relaxed mb-8 animate-on-scroll delay-200">
        New to Trellis? Start with the full platform and billing included from day one.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center animate-on-scroll delay-300">
        <Button href="/contact" variant="primary" size="lg">
          Add Billing to Your Practice
        </Button>
        <Button href="/" variant="secondary" size="lg">
          Explore the Platform
        </Button>
      </div>
    </div>
  </Section>

  <!-- CTA -->
  <section class="relative bg-sage-800 py-20 md:py-28 overflow-hidden">
    <div class="absolute top-0 right-0 w-80 h-80 bg-sage-700/30 rounded-full -translate-y-1/2 translate-x-1/2"></div>
    <div class="absolute bottom-0 left-0 w-64 h-64 bg-sage-700/20 rounded-full translate-y-1/3 -translate-x-1/3"></div>

    <div class="max-w-[800px] mx-auto px-6 text-center relative z-10">
      <h2 class="text-3xl md:text-4xl font-bold text-white mb-6 animate-on-scroll">
        Your notes are already done.<br />Let your billing be, too.
      </h2>
      <p class="text-lg text-sage-200 mb-10 max-w-xl mx-auto animate-on-scroll delay-100">
        See how Trellis Billing can eliminate the gap between clinical work and getting paid.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center animate-on-scroll delay-200">
        <a href="/contact" class="inline-flex items-center justify-center px-8 py-3.5 text-base font-semibold rounded-lg bg-white text-sage-800 hover:bg-warm-100 transition-all duration-200 shadow-sm hover:shadow-md">
          Book a Demo
        </a>
        <a href="mailto:billing@trellis.health" class="inline-flex items-center justify-center px-8 py-3.5 text-base font-semibold rounded-lg border-2 border-sage-400 text-sage-100 hover:bg-sage-700 transition-all duration-200">
          billing@trellis.health
        </a>
      </div>
    </div>
  </section>

</Layout>
