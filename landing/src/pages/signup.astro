---
import Layout from '../layouts/Layout.astro'
import Section from '../components/Section.astro'
---

<Layout title="Sign Up — Trellis" description="Sign the BAA, choose your plan, and get your API key.">

  <!-- HERO -->
  <section class="pt-28 pb-12 md:pt-36 md:pb-16">
    <div class="max-w-[800px] mx-auto px-6 text-center">
      <h1 class="text-3xl md:text-4xl font-bold tracking-tight text-warm-950 mb-4 animate-fade-in">
        Get Started with Trellis Services
      </h1>
      <p class="text-lg text-warm-600 max-w-xl mx-auto animate-fade-in delay-100">
        Sign the Business Associate Agreement, choose your plan, and connect your Trellis instance in minutes.
      </p>
    </div>
  </section>

  <!-- STEP INDICATORS -->
  <div class="max-w-[800px] mx-auto px-6 mb-12">
    <div class="flex items-center justify-center gap-0">
      <!-- Step 1 -->
      <div class="flex items-center gap-2" id="step-indicator-1">
        <div class="w-8 h-8 rounded-full bg-sage-700 text-white flex items-center justify-center text-sm font-bold" id="step-circle-1">1</div>
        <span class="text-sm font-medium text-sage-700" id="step-label-1">Sign BAA</span>
      </div>
      <div class="w-12 h-0.5 bg-warm-200 mx-2" id="step-line-1"></div>
      <!-- Step 2 -->
      <div class="flex items-center gap-2" id="step-indicator-2">
        <div class="w-8 h-8 rounded-full bg-warm-200 text-warm-500 flex items-center justify-center text-sm font-bold" id="step-circle-2">2</div>
        <span class="text-sm font-medium text-warm-400" id="step-label-2">Choose Plan</span>
      </div>
      <div class="w-12 h-0.5 bg-warm-200 mx-2" id="step-line-2"></div>
      <!-- Step 3 -->
      <div class="flex items-center gap-2" id="step-indicator-3">
        <div class="w-8 h-8 rounded-full bg-warm-200 text-warm-500 flex items-center justify-center text-sm font-bold" id="step-circle-3">3</div>
        <span class="text-sm font-medium text-warm-400" id="step-label-3">API Key</span>
      </div>
    </div>
  </div>

  <!-- ================================================================== -->
  <!-- STEP 1: BAA -->
  <!-- ================================================================== -->
  <div id="step-1" class="max-w-[800px] mx-auto px-6 pb-20">
    <div class="bg-white rounded-2xl border border-warm-200 shadow-sm overflow-hidden">
      <div class="px-8 py-6 border-b border-warm-100 bg-sage-50">
        <h2 class="text-xl font-bold text-warm-900">Business Associate Agreement</h2>
        <p class="text-sm text-warm-600 mt-1">
          Required under HIPAA before Trellis can process PHI on your behalf for billing and messaging services.
        </p>
      </div>

      <div class="px-8 py-6 max-h-[400px] overflow-y-auto text-sm text-warm-700 leading-relaxed space-y-4 border-b border-warm-100" id="baa-content">
        <p class="font-semibold text-warm-900">BUSINESS ASSOCIATE AGREEMENT</p>
        <p>This Business Associate Agreement ("BAA") is entered into between the undersigned healthcare practice ("Covered Entity") and Trellis Health, Inc. ("Business Associate"), effective as of the date of electronic signature below.</p>

        <p class="font-semibold text-warm-900 mt-6">1. DEFINITIONS</p>
        <p>Terms used but not otherwise defined in this BAA shall have the same meaning as those terms defined in 45 CFR Parts 160 and 164 (the "HIPAA Rules"). "Protected Health Information" or "PHI" means individually identifiable health information transmitted or maintained in any form or medium, including electronic PHI ("ePHI").</p>

        <p class="font-semibold text-warm-900 mt-6">2. SCOPE OF SERVICES</p>
        <p>Business Associate provides the following services that may involve the use or disclosure of PHI:</p>
        <ul class="list-disc pl-6 space-y-1">
          <li><strong>Text Messaging Service:</strong> Appointment reminders, intake notifications, and billing communications sent via SMS/MMS on behalf of the Covered Entity.</li>
          <li><strong>Billing Service:</strong> Electronic claim submission (837P), eligibility verification (270/271), electronic remittance advice (835) processing, and patient payment collection on behalf of the Covered Entity.</li>
        </ul>

        <p class="font-semibold text-warm-900 mt-6">3. OBLIGATIONS OF BUSINESS ASSOCIATE</p>
        <p>Business Associate agrees to:</p>
        <ul class="list-disc pl-6 space-y-1">
          <li>Not use or disclose PHI other than as permitted or required by this BAA or as required by law.</li>
          <li>Use appropriate administrative, physical, and technical safeguards to prevent unauthorized use or disclosure of PHI, including implementing the requirements of the Security Rule (45 CFR Part 164, Subpart C).</li>
          <li>Report to Covered Entity any use or disclosure of PHI not provided for by this BAA of which it becomes aware, including breaches of unsecured PHI as required by 45 CFR 164.410.</li>
          <li>Ensure that any subcontractors that create, receive, maintain, or transmit PHI on behalf of the Business Associate agree to the same restrictions and conditions that apply to the Business Associate under this BAA.</li>
          <li>Make available PHI in accordance with 45 CFR 164.524 (individual's right of access).</li>
          <li>Make available PHI for amendment and incorporate any amendments to PHI in accordance with 45 CFR 164.526.</li>
          <li>Maintain and make available information required to provide an accounting of disclosures in accordance with 45 CFR 164.528.</li>
          <li>Make its internal practices, books, and records relating to the use and disclosure of PHI available to the Secretary of HHS for purposes of determining Covered Entity's compliance with the HIPAA Rules.</li>
        </ul>

        <p class="font-semibold text-warm-900 mt-6">4. PERMITTED USES AND DISCLOSURES</p>
        <p>Business Associate may use or disclose PHI solely to perform services outlined in Section 2 of this BAA. Business Associate may use PHI for its proper management and administration or to carry out its legal responsibilities, provided that any disclosure for such purposes is required by law or Business Associate obtains reasonable assurance that the information will be held confidentially.</p>

        <p class="font-semibold text-warm-900 mt-6">5. TERM AND TERMINATION</p>
        <p>This BAA shall be effective upon electronic signature and shall continue in effect until all PHI has been destroyed or returned, or protections are extended in accordance with Section 6 of this BAA. Either party may terminate this BAA for cause upon 30 days written notice if the other party materially breaches this BAA and fails to cure such breach within that 30-day period.</p>

        <p class="font-semibold text-warm-900 mt-6">6. EFFECT OF TERMINATION</p>
        <p>Upon termination, Business Associate shall, if feasible, return or destroy all PHI received from or created or received on behalf of Covered Entity. If return or destruction is not feasible, Business Associate shall extend the protections of this BAA to the remaining PHI and limit further uses and disclosures to those purposes that make the return or destruction infeasible.</p>

        <p class="font-semibold text-warm-900 mt-6">7. MISCELLANEOUS</p>
        <ul class="list-disc pl-6 space-y-1">
          <li>This BAA shall be governed by and construed in accordance with applicable federal law, and where not preempted, the laws of the State of Delaware.</li>
          <li>This BAA may not be amended except by written agreement of the parties.</li>
          <li>The obligations of Business Associate under this BAA shall survive the termination of this BAA.</li>
        </ul>
      </div>

      <!-- Signature Form -->
      <div class="px-8 py-6 space-y-4">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
          <div>
            <label class="block text-xs font-medium text-warm-600 mb-1">Practice Name *</label>
            <input type="text" id="baa-practice-name" required
              class="w-full px-3 py-2 text-sm border border-warm-200 rounded-lg focus:outline-none focus:ring-2 focus:ring-sage-500/20 focus:border-sage-400"
              placeholder="Your Practice, LLC" />
          </div>
          <div>
            <label class="block text-xs font-medium text-warm-600 mb-1">Your Full Name *</label>
            <input type="text" id="baa-signer-name" required
              class="w-full px-3 py-2 text-sm border border-warm-200 rounded-lg focus:outline-none focus:ring-2 focus:ring-sage-500/20 focus:border-sage-400"
              placeholder="Dr. Jane Smith" />
          </div>
          <div>
            <label class="block text-xs font-medium text-warm-600 mb-1">Title *</label>
            <input type="text" id="baa-signer-title" required
              class="w-full px-3 py-2 text-sm border border-warm-200 rounded-lg focus:outline-none focus:ring-2 focus:ring-sage-500/20 focus:border-sage-400"
              placeholder="Owner / Clinical Director" />
          </div>
          <div>
            <label class="block text-xs font-medium text-warm-600 mb-1">Email *</label>
            <input type="email" id="baa-email" required
              class="w-full px-3 py-2 text-sm border border-warm-200 rounded-lg focus:outline-none focus:ring-2 focus:ring-sage-500/20 focus:border-sage-400"
              placeholder="jane@yourpractice.com" />
          </div>
        </div>

        <div class="flex items-start gap-3 mt-4">
          <input type="checkbox" id="baa-agree" class="mt-1 rounded border-warm-300 text-sage-600 focus:ring-sage-500" />
          <label for="baa-agree" class="text-sm text-warm-700">
            I have read and agree to the terms of this Business Associate Agreement. I am authorized to sign on behalf of the practice named above.
          </label>
        </div>

        <div id="baa-error" class="hidden text-sm text-red-600 bg-red-50 border border-red-200 rounded-lg px-4 py-2"></div>

        <button id="baa-sign-btn" disabled
          class="mt-4 inline-flex items-center justify-center px-8 py-3 text-sm font-semibold rounded-lg bg-sage-700 text-white hover:bg-sage-800 transition-all duration-200 shadow-sm disabled:opacity-50 disabled:cursor-not-allowed">
          Sign Agreement & Continue
        </button>
      </div>
    </div>
  </div>

  <!-- ================================================================== -->
  <!-- STEP 2: PLAN SELECTION -->
  <!-- ================================================================== -->
  <div id="step-2" class="hidden max-w-[800px] mx-auto px-6 pb-20">
    <div class="bg-white rounded-2xl border border-warm-200 shadow-sm overflow-hidden">
      <div class="px-8 py-6 border-b border-warm-100 bg-sage-50">
        <h2 class="text-xl font-bold text-warm-900">Choose Your Plan</h2>
        <p class="text-sm text-warm-600 mt-1">Select the services you need. You can always add or change later.</p>
      </div>

      <div class="px-8 py-8 space-y-6">
        <!-- Text Messaging Plan -->
        <label class="block cursor-pointer" id="plan-messaging-label">
          <div class="flex items-start gap-4 p-5 rounded-xl border-2 border-warm-200 hover:border-sage-300 transition-colors" id="plan-messaging-card">
            <input type="checkbox" id="plan-messaging" value="messaging"
              class="mt-1 rounded border-warm-300 text-sage-600 focus:ring-sage-500" />
            <div class="flex-1">
              <div class="flex items-center justify-between">
                <h3 class="text-base font-semibold text-warm-900">Text Messaging</h3>
                <span class="text-lg font-bold text-sage-700">$3<span class="text-sm font-normal text-warm-500">/mo</span></span>
              </div>
              <p class="text-sm text-warm-600 mt-1">
                HIPAA-compliant SMS for appointment reminders, intake follow-ups, and billing notifications. Sent from your practice number.
              </p>
              <ul class="mt-3 space-y-1">
                <li class="flex items-center gap-2 text-xs text-warm-600">
                  <svg class="w-3.5 h-3.5 text-sage-500" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" /></svg>
                  Appointment reminders & confirmations
                </li>
                <li class="flex items-center gap-2 text-xs text-warm-600">
                  <svg class="w-3.5 h-3.5 text-sage-500" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" /></svg>
                  Intake form & document signing links
                </li>
                <li class="flex items-center gap-2 text-xs text-warm-600">
                  <svg class="w-3.5 h-3.5 text-sage-500" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" /></svg>
                  Patient balance notifications
                </li>
              </ul>
            </div>
          </div>
        </label>

        <!-- Billing Plan -->
        <label class="block cursor-pointer" id="plan-billing-label">
          <div class="flex items-start gap-4 p-5 rounded-xl border-2 border-warm-200 hover:border-sage-300 transition-colors" id="plan-billing-card">
            <input type="checkbox" id="plan-billing" value="billing"
              class="mt-1 rounded border-warm-300 text-sage-600 focus:ring-sage-500" />
            <div class="flex-1">
              <div class="flex items-center justify-between">
                <h3 class="text-base font-semibold text-warm-900">Automated Billing</h3>
                <span class="text-lg font-bold text-sage-700">3%<span class="text-sm font-normal text-warm-500"> per payment</span></span>
              </div>
              <p class="text-sm text-warm-600 mt-1">
                Full revenue cycle automation. 3% platform fee on each patient payment, calculated after Stripe processing fees.
              </p>
              <ul class="mt-3 space-y-1">
                <li class="flex items-center gap-2 text-xs text-warm-600">
                  <svg class="w-3.5 h-3.5 text-sage-500" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" /></svg>
                  Electronic claim submission (837P)
                </li>
                <li class="flex items-center gap-2 text-xs text-warm-600">
                  <svg class="w-3.5 h-3.5 text-sage-500" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" /></svg>
                  Real-time eligibility verification
                </li>
                <li class="flex items-center gap-2 text-xs text-warm-600">
                  <svg class="w-3.5 h-3.5 text-sage-500" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" /></svg>
                  ERA/835 auto-posting
                </li>
                <li class="flex items-center gap-2 text-xs text-warm-600">
                  <svg class="w-3.5 h-3.5 text-sage-500" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" /></svg>
                  Patient payment via Stripe Connect
                </li>
                <li class="flex items-center gap-2 text-xs text-warm-600">
                  <svg class="w-3.5 h-3.5 text-sage-500" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" /></svg>
                  Denial management & appeals
                </li>
              </ul>
            </div>
          </div>
        </label>

        <!-- Pricing note -->
        <div class="bg-warm-50 rounded-xl p-4 text-sm text-warm-600">
          <p class="font-medium text-warm-700 mb-1">Pricing notes</p>
          <ul class="space-y-1 text-xs">
            <li>Text Messaging: flat $3/month billed via Stripe subscription.</li>
            <li>Billing: 3% platform fee per patient payment, deducted after Stripe's processing fee. No monthly minimum.</li>
            <li>Both plans can be combined. Cancel anytime.</li>
          </ul>
        </div>

        <div id="plan-error" class="hidden text-sm text-red-600 bg-red-50 border border-red-200 rounded-lg px-4 py-2"></div>

        <button id="plan-continue-btn" disabled
          class="mt-2 inline-flex items-center justify-center px-8 py-3 text-sm font-semibold rounded-lg bg-sage-700 text-white hover:bg-sage-800 transition-all duration-200 shadow-sm disabled:opacity-50 disabled:cursor-not-allowed">
          Continue to Payment
        </button>
      </div>
    </div>
  </div>

  <!-- ================================================================== -->
  <!-- STEP 3: API KEY -->
  <!-- ================================================================== -->
  <div id="step-3" class="hidden max-w-[800px] mx-auto px-6 pb-20">
    <div class="bg-white rounded-2xl border border-warm-200 shadow-sm overflow-hidden">
      <div class="px-8 py-6 border-b border-warm-100 bg-sage-50">
        <div class="flex items-center gap-3">
          <div class="w-10 h-10 rounded-full bg-sage-600 flex items-center justify-center">
            <svg class="w-5 h-5 text-white" viewBox="0 0 20 20" fill="currentColor">
              <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
            </svg>
          </div>
          <div>
            <h2 class="text-xl font-bold text-warm-900">You're All Set</h2>
            <p class="text-sm text-warm-600">Your API key has been generated. Copy it now — it won't be shown again.</p>
          </div>
        </div>
      </div>

      <div class="px-8 py-8 space-y-6">
        <!-- API Key display -->
        <div>
          <label class="block text-xs font-medium text-warm-600 mb-2">Your API Key</label>
          <div class="flex items-center gap-2">
            <code id="api-key-display" class="flex-1 px-4 py-3 bg-warm-100 rounded-lg text-sm font-mono text-warm-900 border border-warm-200 select-all break-all">
              Loading...
            </code>
            <button id="copy-key-btn"
              class="shrink-0 px-4 py-3 text-sm font-medium rounded-lg bg-sage-700 text-white hover:bg-sage-800 transition-colors">
              Copy
            </button>
          </div>
          <p class="text-xs text-red-600 mt-2 font-medium">
            Save this key securely. It will not be shown again after you leave this page.
          </p>
        </div>

        <!-- Active permissions -->
        <div>
          <label class="block text-xs font-medium text-warm-600 mb-2">Active Permissions</label>
          <div class="flex gap-3" id="active-permissions">
            <!-- filled by JS -->
          </div>
        </div>

        <!-- Next steps -->
        <div class="bg-sage-50 rounded-xl p-6 border border-sage-100">
          <h3 class="text-sm font-semibold text-warm-800 mb-3">Next Steps</h3>
          <ol class="space-y-3 text-sm text-warm-700">
            <li class="flex items-start gap-3">
              <span class="w-6 h-6 rounded-full bg-sage-200 text-sage-700 flex items-center justify-center text-xs font-bold shrink-0">1</span>
              <span>Open your Trellis instance and navigate to <strong>Settings &rarr; Billing Service</strong>.</span>
            </li>
            <li class="flex items-start gap-3">
              <span class="w-6 h-6 rounded-full bg-sage-200 text-sage-700 flex items-center justify-center text-xs font-bold shrink-0">2</span>
              <span>Paste your API key and click <strong>Connect</strong>.</span>
            </li>
            <li class="flex items-start gap-3">
              <span class="w-6 h-6 rounded-full bg-sage-200 text-sage-700 flex items-center justify-center text-xs font-bold shrink-0">3</span>
              <span id="step-3-billing-note" class="hidden">Complete <strong>Stripe Connect</strong> onboarding to receive patient payments directly into your bank account.</span>
              <span id="step-3-default-note">Your selected services will activate automatically once the key is connected.</span>
            </li>
          </ol>
        </div>

        <a href="/" class="inline-flex items-center gap-2 text-sm text-sage-700 font-medium hover:text-sage-800 transition-colors">
          <svg class="w-4 h-4" viewBox="0 0 20 20" fill="currentColor">
            <path fill-rule="evenodd" d="M17 10a.75.75 0 01-.75.75H5.612l4.158 3.96a.75.75 0 11-1.04 1.08l-5.5-5.25a.75.75 0 010-1.08l5.5-5.25a.75.75 0 111.04 1.08L5.612 9.25H16.25A.75.75 0 0117 10z" clip-rule="evenodd" />
          </svg>
          Back to Home
        </a>
      </div>
    </div>
  </div>

  <!-- ================================================================== -->
  <!-- CLIENT-SIDE LOGIC -->
  <!-- ================================================================== -->
  <script>
    // ----- State -----
    let currentStep = 1;
    let baaData: { practice_name: string; signer_name: string; signer_title: string; email: string } | null = null;
    let selectedPlans: string[] = [];

    // ----- DOM refs -----
    const step1 = document.getElementById('step-1')!;
    const step2 = document.getElementById('step-2')!;
    const step3 = document.getElementById('step-3')!;

    const baaAgree = document.getElementById('baa-agree') as HTMLInputElement;
    const baaSignBtn = document.getElementById('baa-sign-btn') as HTMLButtonElement;
    const baaError = document.getElementById('baa-error')!;

    const planMessaging = document.getElementById('plan-messaging') as HTMLInputElement;
    const planBilling = document.getElementById('plan-billing') as HTMLInputElement;
    const planContinueBtn = document.getElementById('plan-continue-btn') as HTMLButtonElement;
    const planError = document.getElementById('plan-error')!;

    const apiKeyDisplay = document.getElementById('api-key-display')!;
    const copyKeyBtn = document.getElementById('copy-key-btn')!;
    const activePermissions = document.getElementById('active-permissions')!;

    // ----- Step navigation -----
    function goToStep(step: number) {
      currentStep = step;
      step1.classList.toggle('hidden', step !== 1);
      step2.classList.toggle('hidden', step !== 2);
      step3.classList.toggle('hidden', step !== 3);

      for (let i = 1; i <= 3; i++) {
        const circle = document.getElementById(`step-circle-${i}`)!;
        const label = document.getElementById(`step-label-${i}`)!;
        const line = document.getElementById(`step-line-${i}`);

        if (i < step) {
          // Completed
          circle.className = 'w-8 h-8 rounded-full bg-sage-600 text-white flex items-center justify-center text-sm font-bold';
          circle.innerHTML = '<svg class="w-4 h-4" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" /></svg>';
          label.className = 'text-sm font-medium text-sage-600';
          if (line) line.className = 'w-12 h-0.5 bg-sage-400 mx-2';
        } else if (i === step) {
          // Active
          circle.className = 'w-8 h-8 rounded-full bg-sage-700 text-white flex items-center justify-center text-sm font-bold';
          circle.textContent = String(i);
          label.className = 'text-sm font-medium text-sage-700';
        } else {
          // Future
          circle.className = 'w-8 h-8 rounded-full bg-warm-200 text-warm-500 flex items-center justify-center text-sm font-bold';
          circle.textContent = String(i);
          label.className = 'text-sm font-medium text-warm-400';
        }
      }

      window.scrollTo({ top: 0, behavior: 'smooth' });
    }

    // ----- Step 1: BAA -----
    baaAgree.addEventListener('change', () => {
      baaSignBtn.disabled = !baaAgree.checked;
    });

    baaSignBtn.addEventListener('click', () => {
      const practiceName = (document.getElementById('baa-practice-name') as HTMLInputElement).value.trim();
      const signerName = (document.getElementById('baa-signer-name') as HTMLInputElement).value.trim();
      const signerTitle = (document.getElementById('baa-signer-title') as HTMLInputElement).value.trim();
      const email = (document.getElementById('baa-email') as HTMLInputElement).value.trim();

      if (!practiceName || !signerName || !signerTitle || !email) {
        baaError.textContent = 'Please fill in all fields.';
        baaError.classList.remove('hidden');
        return;
      }
      if (!/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email)) {
        baaError.textContent = 'Please enter a valid email address.';
        baaError.classList.remove('hidden');
        return;
      }

      baaError.classList.add('hidden');
      baaData = { practice_name: practiceName, signer_name: signerName, signer_title: signerTitle, email };
      goToStep(2);
    });

    // ----- Step 2: Plan selection -----
    function updatePlanButton() {
      const hasSelection = planMessaging.checked || planBilling.checked;
      planContinueBtn.disabled = !hasSelection;

      // Highlight selected cards
      const msgCard = document.getElementById('plan-messaging-card')!;
      const billCard = document.getElementById('plan-billing-card')!;

      msgCard.className = planMessaging.checked
        ? 'flex items-start gap-4 p-5 rounded-xl border-2 border-sage-500 bg-sage-50/50 transition-colors'
        : 'flex items-start gap-4 p-5 rounded-xl border-2 border-warm-200 hover:border-sage-300 transition-colors';

      billCard.className = planBilling.checked
        ? 'flex items-start gap-4 p-5 rounded-xl border-2 border-sage-500 bg-sage-50/50 transition-colors'
        : 'flex items-start gap-4 p-5 rounded-xl border-2 border-warm-200 hover:border-sage-300 transition-colors';
    }

    planMessaging.addEventListener('change', updatePlanButton);
    planBilling.addEventListener('change', updatePlanButton);

    planContinueBtn.addEventListener('click', async () => {
      selectedPlans = [];
      if (planMessaging.checked) selectedPlans.push('messaging');
      if (planBilling.checked) selectedPlans.push('billing');

      if (selectedPlans.length === 0) {
        planError.textContent = 'Please select at least one plan.';
        planError.classList.remove('hidden');
        return;
      }

      planError.classList.add('hidden');
      planContinueBtn.disabled = true;
      planContinueBtn.innerHTML = '<span class="w-4 h-4 block border-2 border-white/30 border-t-white rounded-full animate-spin mr-2"></span> Processing...';

      try {
        // Call billing service to create account + generate API key
        const resp = await fetch('https://billing.trellis.health/billing/accounts/signup', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            practice_name: baaData!.practice_name,
            signer_name: baaData!.signer_name,
            signer_title: baaData!.signer_title,
            email: baaData!.email,
            plans: selectedPlans,
          }),
        });

        if (!resp.ok) {
          const err = await resp.json().catch(() => ({ detail: 'Signup failed' }));
          throw new Error(err.detail || 'Signup failed');
        }

        const data = await resp.json();

        // If messaging is selected, redirect to Stripe checkout first
        if (data.checkout_url) {
          // Stripe will redirect back to /signup/success?session_id=xxx&api_key=xxx
          window.location.href = data.checkout_url;
          return;
        }

        // No Stripe checkout needed (billing-only, usage-based) — show API key directly
        showApiKey(data.api_key, selectedPlans);
      } catch (err: any) {
        planError.textContent = err.message || 'Something went wrong. Please try again.';
        planError.classList.remove('hidden');
        planContinueBtn.disabled = false;
        planContinueBtn.textContent = 'Continue to Payment';
      }
    });

    // ----- Step 3: API Key display -----
    function showApiKey(key: string, plans: string[]) {
      apiKeyDisplay.textContent = key;

      activePermissions.innerHTML = plans.map(p => {
        const label = p === 'messaging' ? 'Text Messaging' : 'Automated Billing';
        return `<span class="inline-flex items-center gap-1.5 px-3 py-1.5 text-xs font-medium text-sage-700 bg-sage-100 border border-sage-200 rounded-full">
          <svg class="w-3.5 h-3.5 text-sage-500" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" /></svg>
          ${label}
        </span>`;
      }).join('');

      if (plans.includes('billing')) {
        document.getElementById('step-3-billing-note')!.classList.remove('hidden');
        document.getElementById('step-3-default-note')!.classList.add('hidden');
      }

      goToStep(3);
    }

    // ----- Copy button -----
    copyKeyBtn.addEventListener('click', () => {
      const key = apiKeyDisplay.textContent || '';
      navigator.clipboard.writeText(key).then(() => {
        copyKeyBtn.textContent = 'Copied!';
        setTimeout(() => { copyKeyBtn.textContent = 'Copy'; }, 2000);
      });
    });

    // ----- Check for return from Stripe Checkout -----
    const urlParams = new URLSearchParams(window.location.search);
    const returnedApiKey = urlParams.get('api_key');
    const returnedPlans = urlParams.get('plans');
    if (returnedApiKey) {
      const plans = returnedPlans ? returnedPlans.split(',') : ['messaging'];
      showApiKey(returnedApiKey, plans);
    }
  </script>

</Layout>
