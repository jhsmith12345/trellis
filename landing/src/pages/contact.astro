---
import Layout from '../layouts/Layout.astro'
import Section from '../components/Section.astro'
---

<Layout title="Contact — Trellis" description="Book a demo or get in touch with the Trellis team. We'd love to learn about your practice.">

  <!-- HERO -->
  <section class="relative hero-pattern pt-28 pb-12 md:pt-36 md:pb-16 overflow-hidden">
    <div class="max-w-[1200px] mx-auto px-6 relative z-10">
      <div class="max-w-2xl">
        <h1 class="text-4xl md:text-5xl font-bold tracking-tight text-warm-950 leading-[1.1] mb-4 animate-on-scroll">
          Let's talk about<br />
          <span class="text-sage-600">your practice.</span>
        </h1>
        <p class="text-lg text-warm-600 leading-relaxed animate-on-scroll delay-100">
          Whether you're a solo therapist exploring automation or a group practice ready to scale, we'd love to learn about your workflow and show you how Trellis can help.
        </p>
      </div>
    </div>
  </section>

  <!-- CONTACT FORM + INFO -->
  <Section>
    <div class="grid grid-cols-1 lg:grid-cols-5 gap-16">

      <!-- Form -->
      <div class="lg:col-span-3">
        <form class="space-y-6" action="https://formspree.io/f/placeholder" method="POST">
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
            <div>
              <label for="name" class="block text-sm font-medium text-warm-800 mb-2">Your Name</label>
              <input
                type="text"
                id="name"
                name="name"
                required
                class="w-full px-4 py-3 rounded-lg border border-warm-300 bg-white text-warm-900 placeholder-warm-400 focus:outline-none focus:ring-2 focus:ring-sage-500 focus:border-sage-500 transition-colors"
                placeholder="Dr. Jane Smith"
              />
            </div>
            <div>
              <label for="email" class="block text-sm font-medium text-warm-800 mb-2">Email Address</label>
              <input
                type="email"
                id="email"
                name="email"
                required
                class="w-full px-4 py-3 rounded-lg border border-warm-300 bg-white text-warm-900 placeholder-warm-400 focus:outline-none focus:ring-2 focus:ring-sage-500 focus:border-sage-500 transition-colors"
                placeholder="jane@example.com"
              />
            </div>
          </div>

          <div>
            <label for="practice" class="block text-sm font-medium text-warm-800 mb-2">Practice Name</label>
            <input
              type="text"
              id="practice"
              name="practice_name"
              class="w-full px-4 py-3 rounded-lg border border-warm-300 bg-white text-warm-900 placeholder-warm-400 focus:outline-none focus:ring-2 focus:ring-sage-500 focus:border-sage-500 transition-colors"
              placeholder="Serenity Counseling, LLC"
            />
          </div>

          <div>
            <label for="size" class="block text-sm font-medium text-warm-800 mb-2">Practice Size</label>
            <select
              id="size"
              name="practice_size"
              class="w-full px-4 py-3 rounded-lg border border-warm-300 bg-white text-warm-900 focus:outline-none focus:ring-2 focus:ring-sage-500 focus:border-sage-500 transition-colors"
            >
              <option value="">Select your practice size</option>
              <option value="solo">Solo Practice (1 clinician)</option>
              <option value="small-group">Small Group (2-5 clinicians)</option>
              <option value="large-group">Large Group (6-20 clinicians)</option>
              <option value="iop-php">IOP / PHP Program</option>
              <option value="hospital">Hospital / Health System</option>
            </select>
          </div>

          <div>
            <label for="interest" class="block text-sm font-medium text-warm-800 mb-2">What are you most interested in?</label>
            <select
              id="interest"
              name="interest"
              class="w-full px-4 py-3 rounded-lg border border-warm-300 bg-white text-warm-900 focus:outline-none focus:ring-2 focus:ring-sage-500 focus:border-sage-500 transition-colors"
            >
              <option value="">Select an option</option>
              <option value="demo">Book a Demo</option>
              <option value="full-platform">Full Platform (EHR + Billing)</option>
              <option value="billing-only">Billing Add-On (existing Trellis user)</option>
              <option value="open-source">Open Source / Self-Hosted</option>
              <option value="enterprise">Enterprise / Custom Deployment</option>
              <option value="other">Something Else</option>
            </select>
          </div>

          <div>
            <label for="message" class="block text-sm font-medium text-warm-800 mb-2">Message</label>
            <textarea
              id="message"
              name="message"
              rows="5"
              class="w-full px-4 py-3 rounded-lg border border-warm-300 bg-white text-warm-900 placeholder-warm-400 focus:outline-none focus:ring-2 focus:ring-sage-500 focus:border-sage-500 transition-colors resize-vertical"
              placeholder="Tell us about your practice and what you're looking for..."
            ></textarea>
          </div>

          <button
            type="submit"
            class="inline-flex items-center justify-center px-8 py-3.5 text-base font-semibold text-white bg-sage-700 rounded-lg hover:bg-sage-800 transition-all duration-200 shadow-sm hover:shadow-md cursor-pointer w-full sm:w-auto"
          >
            Send Message
            <svg class="w-4 h-4 ml-2" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <line x1="22" y1="2" x2="11" y2="13" /><polygon points="22 2 15 22 11 13 2 9 22 2" />
            </svg>
          </button>
        </form>
      </div>

      <!-- Contact info sidebar -->
      <div class="lg:col-span-2">
        <div class="bg-sage-50 rounded-2xl border border-sage-100 p-8 mb-8">
          <h3 class="text-lg font-semibold text-warm-900 mb-4">Book a Demo</h3>
          <p class="text-warm-600 text-sm leading-relaxed mb-6">
            See Trellis in action with a personalized walkthrough. We'll show you how the platform handles your specific workflow — from intake to payment.
          </p>
          <p class="text-sm text-warm-500">
            Demos typically take 30 minutes. We'll follow up within one business day.
          </p>
        </div>

        <div class="space-y-6">
          <div>
            <h4 class="text-sm font-semibold text-warm-800 uppercase tracking-wider mb-2">Email</h4>
            <a href="mailto:hello@trellis.health" class="text-sage-600 hover:text-sage-700 transition-colors font-medium">
              hello@trellis.health
            </a>
          </div>

          <div>
            <h4 class="text-sm font-semibold text-warm-800 uppercase tracking-wider mb-2">For Billing Inquiries</h4>
            <a href="mailto:billing@trellis.health" class="text-sage-600 hover:text-sage-700 transition-colors font-medium">
              billing@trellis.health
            </a>
          </div>

          <div>
            <h4 class="text-sm font-semibold text-warm-800 uppercase tracking-wider mb-2">Open Source</h4>
            <a href="https://github.com/trellis-health/trellis" target="_blank" rel="noopener noreferrer" class="text-sage-600 hover:text-sage-700 transition-colors font-medium">
              github.com/trellis-health/trellis
            </a>
          </div>

          <div>
            <h4 class="text-sm font-semibold text-warm-800 uppercase tracking-wider mb-2">Response Time</h4>
            <p class="text-warm-600 text-sm">
              We respond to all inquiries within one business day. Demo requests are typically scheduled within the week.
            </p>
          </div>
        </div>
      </div>
    </div>
  </Section>

</Layout>
