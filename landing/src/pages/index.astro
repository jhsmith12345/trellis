---
import Layout from '../layouts/Layout.astro'
import Section from '../components/Section.astro'
import Button from '../components/Button.astro'
import FeatureCard from '../components/FeatureCard.astro'
import PackageCard from '../components/PackageCard.astro'

const features = [
  {
    title: 'AI Voice Intake',
    description: 'Your AI front desk handles new client intake calls around the clock. Collects demographics, insurance information, and clinical history through natural conversation — then books the first appointment.',
    icon: '<svg class="w-6 h-6 text-sage-600" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 1a3 3 0 0 0-3 3v8a3 3 0 0 0 6 0V4a3 3 0 0 0-3-3z"/><path d="M19 10v2a7 7 0 0 1-14 0v-2"/><line x1="12" y1="19" x2="12" y2="23"/><line x1="8" y1="23" x2="16" y2="23"/></svg>',
  },
  {
    title: 'Smart Scheduling',
    description: 'Automated booking synced with Google Calendar and Meet. Clients get a video link, you get a clean schedule. Supports recurring appointments, availability rules, and group sessions.',
    icon: '<svg class="w-6 h-6 text-sage-600" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/><path d="M8 14h.01M12 14h.01M16 14h.01M8 18h.01M12 18h.01"/></svg>',
  },
  {
    title: 'AI Clinical Notes',
    description: 'Session recording transforms into structured SOAP, DAP, or narrative notes in minutes. Review, edit, and sign — with full audit trail and SHA-256 integrity verification.',
    icon: '<svg class="w-6 h-6 text-sage-600" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><polyline points="10 9 9 9 8 9"/></svg>',
  },
  {
    title: 'Treatment Plans',
    description: 'AI-generated treatment plans with versioning, review workflow, and digital signatures. Supports multiple note types and tracks treatment goals across the care continuum.',
    icon: '<svg class="w-6 h-6 text-sage-600" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/></svg>',
  },
  {
    title: 'Automated Billing',
    description: 'Clinical note signed? Claim submitted. Insurance paid? Payment posted. Patient balance? Invoice sent. The entire revenue cycle runs on autopilot.',
    icon: '<svg class="w-6 h-6 text-sage-600" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg>',
  },
  {
    title: 'Client Portal',
    description: 'Clients manage their own intake documents, appointments, and billing from a clean, secure portal. E-signatures, consent forms, and payment history all in one place.',
    icon: '<svg class="w-6 h-6 text-sage-600" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>',
  },
]

const steps = [
  {
    number: '01',
    title: 'Install',
    description: 'Deploy Trellis into your own Google Cloud project. Your data, your infrastructure, your control.',
  },
  {
    number: '02',
    title: 'Configure',
    description: 'Set your availability, insurance panels, rates, and practice profile. Connect your Google Workspace.',
  },
  {
    number: '03',
    title: 'Practice',
    description: 'AI handles intake calls, schedules sessions, and generates notes. You focus on your clients.',
  },
  {
    number: '04',
    title: 'Get Paid',
    description: 'Claims submit automatically. Payments post in real time. Denial management runs in the background.',
  },
]

const packages = [
  {
    name: 'Solo Practice',
    tagline: 'For individual therapists ready to automate their practice.',
    features: [
      'Single clinician license',
      'AI voice intake agent',
      'Smart scheduling + Calendar sync',
      'AI clinical note generation',
      'Treatment plan management',
      'Client portal with e-signatures',
      'HIPAA-compliant infrastructure',
    ],
  },
  {
    name: 'Group Practice',
    tagline: 'Multi-clinician teams with shared operations.',
    features: [
      'Everything in Solo Practice',
      'Unlimited clinician seats',
      'Shared billing dashboard',
      'Multi-provider scheduling',
      'Practice-wide reporting',
      'Role-based access controls',
      'Priority support',
    ],
    highlighted: true,
  },
  {
    name: 'IOP / PHP Programs',
    tagline: 'Group therapy management for intensive programs.',
    features: [
      'Everything in Group Practice',
      'Group session management',
      'Recurring group scheduling',
      'Attendance tracking',
      'Multi-session enrollment',
      'Higher-level-of-care workflows',
      'Program outcome reporting',
    ],
  },
  {
    name: 'Enterprise / Hospital',
    tagline: 'Custom deployments for large organizations.',
    features: [
      'Everything in IOP / PHP',
      'Custom integration builds',
      'Dedicated infrastructure',
      'SLA-backed support',
      'Custom compliance controls',
      'On-premise option available',
      'Dedicated success team',
    ],
  },
]

const trustItems = [
  {
    title: 'HIPAA Compliant',
    description: 'Full technical safeguards: encryption at rest and in transit, audit logging, access controls, session management, and data integrity verification.',
    icon: '<svg class="w-6 h-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>',
  },
  {
    title: 'You Own Your Data',
    description: 'Trellis deploys into YOUR Google Cloud. Patient data never touches our servers. You have full control and portability.',
    icon: '<svg class="w-6 h-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="8" rx="2" ry="2"/><rect x="2" y="14" width="20" height="8" rx="2" ry="2"/><line x1="6" y1="6" x2="6.01" y2="6"/><line x1="6" y1="18" x2="6.01" y2="18"/></svg>',
  },
  {
    title: 'Open Source Core',
    description: 'Inspect every line of code. The EHR core is fully open source. No vendor lock-in, no black boxes, no surprises.',
    icon: '<svg class="w-6 h-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/></svg>',
  },
]
---

<Layout title="Trellis — AI-Native Behavioral Health Platform">

  <!-- HERO -->
  <section class="relative hero-pattern pt-28 pb-20 md:pt-36 md:pb-28 overflow-hidden">
    <div class="absolute top-20 -right-32 w-96 h-96 border border-sage-200/30 rounded-full opacity-40"></div>
    <div class="absolute -bottom-48 -left-24 w-[500px] h-[500px] border border-sage-200/20 rounded-full opacity-30"></div>

    <div class="max-w-[1200px] mx-auto px-6 relative z-10">
      <div class="max-w-3xl">
        <div class="animate-fade-in">
          <span class="inline-flex items-center gap-2 px-3 py-1 text-xs font-medium text-sage-700 bg-sage-100 rounded-full mb-6">
            <span class="w-1.5 h-1.5 rounded-full bg-sage-500"></span>
            Open Source EHR + Revenue Cycle
          </span>
        </div>

        <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold tracking-tight text-warm-950 leading-[1.1] mb-6 animate-on-scroll">
          You became a therapist<br class="hidden sm:block" />to help people heal.<br />
          <span class="text-sage-600">Not to fight with clearinghouses.</span>
        </h1>

        <p class="text-lg md:text-xl text-warm-600 max-w-2xl mb-10 leading-relaxed animate-on-scroll delay-100">
          Trellis is the AI-native platform that automates intake, scheduling, clinical documentation, and billing for behavioral health practices. So you can get back to what you actually trained for.
        </p>

        <div class="flex flex-col sm:flex-row gap-4 animate-on-scroll delay-200">
          <Button href="/contact" variant="primary" size="lg">
            Book a Demo
          </Button>
          <Button href="https://github.com/trellis-health/trellis" variant="secondary" size="lg" external>
            <svg class="w-5 h-5 mr-2" viewBox="0 0 24 24" fill="currentColor">
              <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
            </svg>
            View Open Source
          </Button>
        </div>
      </div>
    </div>
  </section>

  <!-- PROBLEM STATEMENT -->
  <Section background="alt">
    <div class="max-w-3xl mx-auto text-center">
      <h2 class="text-3xl md:text-4xl font-bold text-warm-900 mb-6 animate-on-scroll">
        The paperwork is the problem.
      </h2>
      <p class="text-lg text-warm-600 leading-relaxed mb-4 animate-on-scroll delay-100">
        You didn't go to graduate school to spend your evenings writing progress notes, your mornings chasing insurance authorizations, or your weekends reconciling claim denials.
      </p>
      <p class="text-lg text-warm-600 leading-relaxed mb-4 animate-on-scroll delay-200">
        The average behavioral health clinician spends <strong class="text-warm-800">10+ hours per week</strong> on administrative tasks. That's a full day of clinical time lost. Every week.
      </p>
      <p class="text-lg text-warm-700 leading-relaxed font-medium animate-on-scroll delay-300">
        Trellis gives you that day back.
      </p>
    </div>
  </Section>

  <!-- PRODUCT OVERVIEW -->
  <Section id="product">
    <div class="text-center mb-16">
      <h2 class="text-3xl md:text-4xl font-bold text-warm-900 mb-4 animate-on-scroll">
        Everything your practice needs.<br class="hidden md:block" /> Nothing it doesn't.
      </h2>
      <p class="text-lg text-warm-600 max-w-2xl mx-auto animate-on-scroll delay-100">
        Six integrated modules that cover the full clinical and operational workflow — from first phone call to final payment.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {features.map((feature, i) => (
        <div class:list={['animate-on-scroll', `delay-${(i % 3 + 1) * 100}`]}>
          <FeatureCard
            title={feature.title}
            description={feature.description}
            icon={feature.icon}
          />
        </div>
      ))}
    </div>
  </Section>

  <!-- HOW IT WORKS -->
  <Section id="how-it-works" background="sage">
    <div class="text-center mb-16">
      <h2 class="text-3xl md:text-4xl font-bold text-warm-900 mb-4 animate-on-scroll">
        Up and running in days, not months.
      </h2>
      <p class="text-lg text-warm-600 max-w-2xl mx-auto animate-on-scroll delay-100">
        Trellis installs into your own Google Workspace and Cloud infrastructure. You own every byte of patient data.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
      {steps.map((step, i) => (
        <div class:list={['animate-on-scroll', `delay-${(i + 1) * 100}`]}>
          <div class="relative">
            <span class="text-5xl font-bold text-sage-200">{step.number}</span>
            <h3 class="text-xl font-bold text-warm-900 mt-2 mb-3">{step.title}</h3>
            <p class="text-warm-600 text-sm leading-relaxed">{step.description}</p>
            {i < steps.length - 1 && (
              <div class="hidden lg:block absolute top-8 -right-4 w-8 text-sage-300">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <line x1="5" y1="12" x2="19" y2="12" />
                  <polyline points="12 5 19 12 12 19" />
                </svg>
              </div>
            )}
          </div>
        </div>
      ))}
    </div>
  </Section>

  <!-- PACKAGES -->
  <Section id="packages">
    <div class="text-center mb-16">
      <h2 class="text-3xl md:text-4xl font-bold text-warm-900 mb-4 animate-on-scroll">
        A plan for every practice size.
      </h2>
      <p class="text-lg text-warm-600 max-w-2xl mx-auto animate-on-scroll delay-100">
        From solo practitioners to hospital systems. All plans include the open-source EHR core with HIPAA-compliant infrastructure.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
      {packages.map((pkg, i) => (
        <div class:list={['animate-on-scroll', `delay-${(i + 1) * 100}`]}>
          <PackageCard
            name={pkg.name}
            tagline={pkg.tagline}
            features={pkg.features}
            highlighted={pkg.highlighted ?? false}
          />
        </div>
      ))}
    </div>
  </Section>

  <!-- BILLING HIGHLIGHT -->
  <Section background="alt">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
      <div>
        <span class="inline-flex items-center gap-2 px-3 py-1 text-xs font-medium text-terra-700 bg-terra-100 rounded-full mb-6 animate-on-scroll">
          Revenue Cycle Management
        </span>
        <h2 class="text-3xl md:text-4xl font-bold text-warm-900 mb-6 animate-on-scroll delay-100">
          Stop downloading claim files.<br />
          Start getting paid automatically.
        </h2>
        <p class="text-lg text-warm-600 leading-relaxed mb-8 animate-on-scroll delay-200">
          Trellis Billing connects your clinical workflow directly to payers. When a clinician signs a note, the claim builds itself. When insurance pays, the payment posts itself. When there's a patient balance, the invoice sends itself.
        </p>

        <ul class="space-y-4 mb-8">
          {[
            'One-click claim submission (CMS-1500 / 837P)',
            'Real-time eligibility verification',
            'Automatic ERA/835 payment posting',
            'Patient payment collection via Stripe',
            'Denial management and appeals tracking',
            'Financial reporting and analytics',
          ].map((item, i) => (
            <li class:list={['flex items-start gap-3 animate-on-scroll', `delay-${(i % 3 + 1) * 100}`]}>
              <svg class="w-5 h-5 text-sage-500 mt-0.5 shrink-0" viewBox="0 0 20 20" fill="currentColor">
                <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
              </svg>
              <span class="text-warm-700">{item}</span>
            </li>
          ))}
        </ul>

        <Button href="/billing" variant="primary" size="lg">
          Learn About Billing
          <svg class="w-4 h-4 ml-2" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <line x1="5" y1="12" x2="19" y2="12" /><polyline points="12 5 19 12 12 19" />
          </svg>
        </Button>
      </div>

      <!-- Visual billing flow -->
      <div class="animate-scale-in delay-200">
        <div class="bg-white rounded-2xl border border-warm-200 p-8 shadow-sm">
          <h4 class="text-sm font-semibold uppercase tracking-wider text-warm-500 mb-8">How billing flows</h4>
          <div class="space-y-6">
            {[
              { label: 'Note Signed', color: 'sage', detail: 'Clinician completes session note' },
              { label: 'Claim Submitted', color: 'sage', detail: 'CMS-1500 generated and transmitted' },
              { label: 'Insurance Pays', color: 'gold', detail: 'ERA/835 auto-posts to account' },
              { label: 'Patient Balance', color: 'terra', detail: 'Invoice generated with payment link' },
              { label: 'Payment Collected', color: 'sage', detail: 'Stripe processes, ledger updates' },
            ].map((step, i) => (
              <div class="flex items-start gap-4">
                <div class="flex flex-col items-center">
                  <div class:list={[
                    'w-10 h-10 rounded-full flex items-center justify-center text-white text-sm font-bold',
                    step.color === 'sage' ? 'bg-sage-600' : step.color === 'gold' ? 'bg-gold-500' : 'bg-terra-500',
                  ]}>
                    {i + 1}
                  </div>
                  {i < 4 && <div class="w-0.5 h-6 bg-warm-200 mt-2"></div>}
                </div>
                <div class="pt-1.5">
                  <p class="font-semibold text-warm-900 text-sm">{step.label}</p>
                  <p class="text-warm-500 text-xs mt-0.5">{step.detail}</p>
                </div>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </Section>

  <!-- TRUST / COMPLIANCE -->
  <Section>
    <div class="text-center mb-16">
      <h2 class="text-3xl md:text-4xl font-bold text-warm-900 mb-4 animate-on-scroll">
        Built for the most sensitive data in healthcare.
      </h2>
      <p class="text-lg text-warm-600 max-w-2xl mx-auto animate-on-scroll delay-100">
        Security and compliance aren't afterthoughts. They're the foundation.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      {trustItems.map((item, i) => (
        <div class:list={['text-center animate-on-scroll', `delay-${(i + 1) * 100}`]}>
          <div class="w-14 h-14 rounded-2xl bg-sage-50 border border-sage-100 flex items-center justify-center mx-auto mb-5 text-sage-600">
            <Fragment set:html={item.icon} />
          </div>
          <h3 class="text-lg font-semibold text-warm-900 mb-2">{item.title}</h3>
          <p class="text-warm-600 text-sm leading-relaxed max-w-sm mx-auto">{item.description}</p>
        </div>
      ))}
    </div>

    <div class="mt-16 flex flex-wrap justify-center gap-4 animate-on-scroll delay-200">
      {[
        'AES-256 Encryption at Rest',
        'TLS 1.3 in Transit',
        'SHA-256 Integrity Hashes',
        'Append-Only Audit Log',
        'Role-Based Access Control',
        'BAA Available',
      ].map((badge) => (
        <span class="inline-flex items-center gap-2 px-4 py-2 text-sm font-medium text-sage-700 bg-sage-50 border border-sage-200 rounded-full">
          <svg class="w-4 h-4 text-sage-500" viewBox="0 0 20 20" fill="currentColor">
            <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
          </svg>
          {badge}
        </span>
      ))}
    </div>
  </Section>

  <!-- FINAL CTA -->
  <section class="relative bg-sage-800 py-20 md:py-28 overflow-hidden">
    <div class="absolute top-0 right-0 w-96 h-96 bg-sage-700/30 rounded-full -translate-y-1/2 translate-x-1/2"></div>
    <div class="absolute bottom-0 left-0 w-72 h-72 bg-sage-700/20 rounded-full translate-y-1/3 -translate-x-1/3"></div>

    <div class="max-w-[800px] mx-auto px-6 text-center relative z-10">
      <h2 class="text-3xl md:text-4xl font-bold text-white mb-6 animate-on-scroll">
        Ready to focus on what matters?
      </h2>
      <p class="text-lg text-sage-200 mb-10 max-w-xl mx-auto animate-on-scroll delay-100">
        Join the behavioral health practices that are reclaiming their time with Trellis. Book a demo and see the platform in action.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center animate-on-scroll delay-200">
        <a href="/contact" class="inline-flex items-center justify-center px-8 py-3.5 text-base font-semibold rounded-lg bg-white text-sage-800 hover:bg-warm-100 transition-all duration-200 shadow-sm hover:shadow-md">
          Book a Demo
        </a>
        <a href="mailto:hello@trellis.health" class="inline-flex items-center justify-center px-8 py-3.5 text-base font-semibold rounded-lg border-2 border-sage-400 text-sage-100 hover:bg-sage-700 transition-all duration-200">
          hello@trellis.health
        </a>
      </div>
    </div>
  </section>

</Layout>
