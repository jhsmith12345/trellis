---
interface Props {
  title: string
  description: string
  icon: string
  class?: string
}

const { title, description, icon, class: className = '' } = Astro.props
---

<div class:list={['group bg-white rounded-2xl p-7 border border-warm-200 hover:border-sage-300 hover:shadow-lg transition-all duration-300', className]}>
  <div class="w-12 h-12 rounded-xl bg-sage-50 flex items-center justify-center mb-5 group-hover:bg-sage-100 transition-colors">
    <Fragment set:html={icon} />
  </div>
  <h3 class="text-lg font-semibold text-warm-900 mb-2">{title}</h3>
  <p class="text-warm-600 text-sm leading-relaxed">{description}</p>
</div>
