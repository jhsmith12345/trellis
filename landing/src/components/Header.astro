---
const navLinks = [
  { label: 'Product', href: '/#product' },
  { label: 'Billing', href: '/billing' },
  { label: 'Packages', href: '/#packages' },
  { label: 'Open Source', href: 'https://github.com/trellis-health/trellis', external: true },
  { label: 'Contact', href: '/contact' },
]
---

<header class="fixed top-0 left-0 right-0 z-50 bg-warm-50/80 backdrop-blur-lg border-b border-warm-200/60">
  <nav class="max-w-[1200px] mx-auto px-6 h-16 flex items-center justify-between">
    <!-- Logo -->
    <a href="/" class="flex items-center gap-2.5 group">
      <svg width="28" height="28" viewBox="0 0 32 32" fill="none" xmlns="http://www.w3.org/2000/svg" class="transition-transform group-hover:scale-105">
        <rect width="32" height="32" rx="8" fill="var(--color-sage-700)" />
        <path d="M16 6C16 6 12 12 12 18C12 22 14 26 16 26C18 26 20 22 20 18C20 12 16 6 16 6Z" fill="var(--color-sage-200)" opacity="0.9"/>
        <path d="M10 10C10 10 12 15 14 18C15.5 20 16 22 16 22" stroke="var(--color-sage-300)" stroke-width="1.5" stroke-linecap="round" opacity="0.7"/>
        <path d="M22 10C22 10 20 15 18 18C16.5 20 16 22 16 22" stroke="var(--color-sage-300)" stroke-width="1.5" stroke-linecap="round" opacity="0.7"/>
      </svg>
      <span class="text-lg font-semibold tracking-tight text-sage-900">Trellis</span>
    </a>

    <!-- Desktop Nav -->
    <div class="hidden md:flex items-center gap-8">
      {navLinks.map((link) => (
        <a
          href={link.href}
          class="text-sm font-medium text-warm-700 hover:text-sage-700 transition-colors"
          {...(link.external ? { target: '_blank', rel: 'noopener noreferrer' } : {})}
        >
          {link.label}
        </a>
      ))}
      <a
        href="/contact"
        class="inline-flex items-center px-4 py-2 text-sm font-semibold text-white bg-sage-700 rounded-lg hover:bg-sage-800 transition-colors shadow-sm"
      >
        Book a Demo
      </a>
    </div>

    <!-- Mobile Menu Button -->
    <button
      id="mobile-menu-btn"
      class="md:hidden p-2 text-warm-700 hover:text-sage-700 transition-colors"
      aria-label="Toggle menu"
    >
      <svg id="menu-icon-open" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
        <line x1="3" y1="6" x2="21" y2="6" />
        <line x1="3" y1="12" x2="21" y2="12" />
        <line x1="3" y1="18" x2="21" y2="18" />
      </svg>
      <svg id="menu-icon-close" class="hidden" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
        <line x1="6" y1="6" x2="18" y2="18" />
        <line x1="6" y1="18" x2="18" y2="6" />
      </svg>
    </button>
  </nav>

  <!-- Mobile Menu -->
  <div id="mobile-menu" class="hidden md:hidden bg-warm-50 border-b border-warm-200 px-6 pb-6">
    <div class="flex flex-col gap-4 pt-2">
      {navLinks.map((link) => (
        <a
          href={link.href}
          class="text-base font-medium text-warm-700 hover:text-sage-700 transition-colors py-1"
          {...(link.external ? { target: '_blank', rel: 'noopener noreferrer' } : {})}
        >
          {link.label}
        </a>
      ))}
      <a
        href="/contact"
        class="inline-flex items-center justify-center px-4 py-2.5 text-sm font-semibold text-white bg-sage-700 rounded-lg hover:bg-sage-800 transition-colors shadow-sm mt-2"
      >
        Book a Demo
      </a>
    </div>
  </div>
</header>

<script>
  const btn = document.getElementById('mobile-menu-btn')
  const menu = document.getElementById('mobile-menu')
  const iconOpen = document.getElementById('menu-icon-open')
  const iconClose = document.getElementById('menu-icon-close')

  btn?.addEventListener('click', () => {
    const isOpen = !menu?.classList.contains('hidden')
    menu?.classList.toggle('hidden')
    iconOpen?.classList.toggle('hidden')
    iconClose?.classList.toggle('hidden')
  })
</script>
