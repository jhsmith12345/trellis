---
interface Props {
  name: string
  tagline: string
  features: string[]
  highlighted?: boolean
  class?: string
}

const { name, tagline, features, highlighted = false, class: className = '' } = Astro.props
---

<div class:list={[
  'rounded-2xl p-8 flex flex-col h-full transition-all duration-300',
  highlighted
    ? 'bg-sage-800 text-white border-2 border-sage-600 shadow-xl shadow-sage-900/20 scale-[1.02]'
    : 'bg-white border border-warm-200 hover:border-sage-300 hover:shadow-lg',
  className,
]}>
  {highlighted && (
    <span class="inline-block text-xs font-semibold uppercase tracking-wider text-gold-400 mb-2">Most Popular</span>
  )}
  <h3 class:list={['text-xl font-bold mb-2', highlighted ? 'text-white' : 'text-warm-900']}>
    {name}
  </h3>
  <p class:list={['text-sm mb-6', highlighted ? 'text-sage-200' : 'text-warm-600']}>
    {tagline}
  </p>
  <ul class="space-y-3 mb-8 flex-1">
    {features.map((feature) => (
      <li class="flex items-start gap-3">
        <svg class:list={['w-5 h-5 mt-0.5 shrink-0', highlighted ? 'text-sage-300' : 'text-sage-500']} viewBox="0 0 20 20" fill="currentColor">
          <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
        </svg>
        <span class:list={['text-sm', highlighted ? 'text-sage-100' : 'text-warm-700']}>
          {feature}
        </span>
      </li>
    ))}
  </ul>
  <a
    href="/contact"
    class:list={[
      'inline-flex items-center justify-center px-6 py-3 text-sm font-semibold rounded-lg transition-all duration-200',
      highlighted
        ? 'bg-white text-sage-800 hover:bg-sage-50 shadow-sm'
        : 'bg-sage-700 text-white hover:bg-sage-800 shadow-sm',
    ]}
  >
    Contact Sales
  </a>
</div>
