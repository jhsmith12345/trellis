---
const currentYear = new Date().getFullYear()

const productLinks = [
  { label: 'Features', href: '/#product' },
  { label: 'Billing', href: '/billing' },
  { label: 'Packages', href: '/#packages' },
  { label: 'How It Works', href: '/#how-it-works' },
]

const companyLinks = [
  { label: 'Contact', href: '/contact' },
  { label: 'Open Source', href: 'https://github.com/trellis-health/trellis' },
  { label: 'Documentation', href: 'https://docs.trellis.health' },
]

const legalLinks = [
  { label: 'Privacy Policy', href: '/privacy' },
  { label: 'Terms of Service', href: '/terms' },
  { label: 'BAA', href: '/baa' },
  { label: 'HIPAA Compliance', href: '/hipaa' },
]
---

<footer class="bg-sage-900 text-sage-200 mt-0">
  <div class="max-w-[1200px] mx-auto px-6 pt-16 pb-8">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-12 mb-16">
      <!-- Brand -->
      <div class="lg:col-span-1">
        <a href="/" class="flex items-center gap-2.5 mb-4">
          <svg width="28" height="28" viewBox="0 0 32 32" fill="none" xmlns="http://www.w3.org/2000/svg">
            <rect width="32" height="32" rx="8" fill="var(--color-sage-600)" />
            <path d="M16 6C16 6 12 12 12 18C12 22 14 26 16 26C18 26 20 22 20 18C20 12 16 6 16 6Z" fill="var(--color-sage-200)" opacity="0.9"/>
            <path d="M10 10C10 10 12 15 14 18C15.5 20 16 22 16 22" stroke="var(--color-sage-300)" stroke-width="1.5" stroke-linecap="round" opacity="0.7"/>
            <path d="M22 10C22 10 20 15 18 18C16.5 20 16 22 16 22" stroke="var(--color-sage-300)" stroke-width="1.5" stroke-linecap="round" opacity="0.7"/>
          </svg>
          <span class="text-lg font-semibold tracking-tight text-white">Trellis</span>
        </a>
        <p class="text-sage-300 text-sm leading-relaxed max-w-xs">
          The AI-native platform built for behavioral health practices. Open source core, enterprise ready.
        </p>
      </div>

      <!-- Product -->
      <div>
        <h4 class="text-sm font-semibold text-white uppercase tracking-wider mb-4">Product</h4>
        <ul class="space-y-3">
          {productLinks.map((link) => (
            <li>
              <a href={link.href} class="text-sm text-sage-300 hover:text-white transition-colors">
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Company -->
      <div>
        <h4 class="text-sm font-semibold text-white uppercase tracking-wider mb-4">Company</h4>
        <ul class="space-y-3">
          {companyLinks.map((link) => (
            <li>
              <a href={link.href} class="text-sm text-sage-300 hover:text-white transition-colors">
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Legal -->
      <div>
        <h4 class="text-sm font-semibold text-white uppercase tracking-wider mb-4">Legal</h4>
        <ul class="space-y-3">
          {legalLinks.map((link) => (
            <li>
              <a href={link.href} class="text-sm text-sage-300 hover:text-white transition-colors">
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>
    </div>

    <!-- Bottom bar -->
    <div class="border-t border-sage-800 pt-8 flex flex-col sm:flex-row justify-between items-center gap-4">
      <p class="text-sm text-sage-400">
        &copy; {currentYear} Trellis Health, Inc. All rights reserved.
      </p>
      <p class="text-sm text-sage-500">
        Built with care for behavioral health.
      </p>
    </div>
  </div>
</footer>
