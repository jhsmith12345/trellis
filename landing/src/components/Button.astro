---
interface Props {
  href?: string
  variant?: 'primary' | 'secondary' | 'outline' | 'ghost'
  size?: 'sm' | 'md' | 'lg'
  class?: string
  external?: boolean
  type?: 'button' | 'submit'
}

const {
  href,
  variant = 'primary',
  size = 'md',
  class: className = '',
  external = false,
  type = 'button',
} = Astro.props

const baseClasses = 'inline-flex items-center justify-center font-semibold rounded-lg transition-all duration-200 cursor-pointer'

const variantClasses = {
  primary: 'bg-sage-700 text-white hover:bg-sage-800 shadow-sm hover:shadow-md',
  secondary: 'bg-white text-sage-800 border border-warm-300 hover:border-sage-400 hover:bg-sage-50 shadow-sm',
  outline: 'border-2 border-sage-300 text-sage-700 hover:bg-sage-50 hover:border-sage-500',
  ghost: 'text-sage-700 hover:bg-sage-50',
}

const sizeClasses = {
  sm: 'px-4 py-2 text-sm',
  md: 'px-6 py-2.5 text-sm',
  lg: 'px-8 py-3.5 text-base',
}

const classes = [baseClasses, variantClasses[variant], sizeClasses[size], className].join(' ')
---

{href ? (
  <a
    href={href}
    class={classes}
    {...(external ? { target: '_blank', rel: 'noopener noreferrer' } : {})}
  >
    <slot />
  </a>
) : (
  <button type={type} class={classes}>
    <slot />
  </button>
)}
