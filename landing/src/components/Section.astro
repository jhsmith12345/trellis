---
interface Props {
  id?: string
  class?: string
  background?: 'default' | 'alt' | 'dark' | 'sage'
  narrow?: boolean
}

const { id, class: className = '', background = 'default', narrow = false } = Astro.props

const bgClasses = {
  default: 'bg-warm-50',
  alt: 'bg-warm-100',
  dark: 'bg-sage-900 text-white',
  sage: 'bg-sage-50',
}
---

<section id={id} class:list={[bgClasses[background], 'py-20 md:py-28', className]}>
  <div class:list={['mx-auto px-6', narrow ? 'max-w-[800px]' : 'max-w-[1200px]']}>
    <slot />
  </div>
</section>
